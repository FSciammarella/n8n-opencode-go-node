{
  "name": "n8n-nodes-opencode-go",
  "version": "0.1.0",
  "description": "n8n community node for OpenCode Go AI provider",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/"
  },
  "files": ["dist/"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/OpenCodeGoApi.credentials.js"],
    "nodes": [
      "dist/nodes/LmChatOpenCodeGo/LmChatOpenCodeGo.node.js",
      "dist/nodes/LmChatOpenCodeGoAnthropic/LmChatOpenCodeGoAnthropic.node.js"
    ]
  },
  "dependencies": {
    "@langchain/openai": "^0.4.0",
    "@langchain/anthropic": "^0.3.0",
    "n8n-workflow": "~1.74.0"
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0"
  }
}
